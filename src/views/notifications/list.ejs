<%- include('../partials/header', { title: 'الإشعارات' }) %>
<div class="container">
  <h1>الإشعارات</h1>

  <% if (notifications.length === 0) { %>
    <p>لا توجد إشعارات حتى الآن.</p>
  <% } else { %>
    <% notifications.forEach(function(n) { %>
      <div class="info-card">
        <strong><%= n.title %></strong>
        <% if (n.body) { %><p><%= n.body %></p><% } %>
        <p class="card-meta"><%= n.created_at %></p>
        <% if (n.link) { %><a href="<%= n.link %>">عرض التفاصيل</a><% } %>
      </div>
    <% }) %>
  <% } %>
</div>
<%- include('../partials/footer') %>
