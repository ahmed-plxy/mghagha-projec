<%- include('../../partials/header', { title: t('app.name') }) %>

<div class="container pf-container">
  <div class="pf-header">
    <a href="/vendor/products" class="back-link">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
      العودة إلى منتجاتي
    </a>
    <h1 class="pf-title"><%= mode === 'create' ? 'إضافة منتج جديد' : 'تعديل المنتج' %></h1>
  </div>

  <% if (errors && errors.length > 0) { %>
    <div class="pf-errors">
      <% errors.forEach(function(err) { %><p>⚠ <%= err %></p><% }) %>
    </div>
  <% } %>

  <form
    action="<%= mode === 'create' ? '/vendor/products/new' : '/vendor/products/' + product.id + '/edit' %>"
    method="POST"
    enctype="multipart/form-data"
    class="pf-form"
    id="productForm"
  >

    <!-- ===== STEP 1: PRODUCT NAME ===== -->
    <div class="pf-section">
      <div class="pf-section-title">
        <span class="pf-step">١</span>
        <span>معلومات المنتج الأساسية</span>
      </div>
      <div class="form-group">
        <label for="name">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          اسم المنتج أو الإعلان
        </label>
        <input
          type="text"
          id="name"
          name="name"
          value="<%= (old && old.name) || (product && product.name) || '' %>"
          placeholder="مثال: موبايل سامسونج S23 للبيع"
          required
          class="pf-input"
        >
      </div>
    </div>

    <!-- ===== STEP 2: CATEGORY ===== -->
    <div class="pf-section">
      <div class="pf-section-title">
        <span class="pf-step">٢</span>
        <span>الفئة والتصنيف</span>
      </div>

      <input type="hidden" id="categoryId" name="categoryId" value="<%= (old && old.categoryId) || (product && product.category_id) || '' %>">

      <!-- Main Category Grid -->
      <div class="form-group">
        <label>الفئة الرئيسية</label>
        <div class="pf-cat-grid" id="mainCatGrid">
          <% mainCategories.forEach(function(cat) { %>
            <button type="button" class="pf-cat-chip" data-id="<%= cat.id %>" data-slug="<%= cat.slug %>">
              <span class="pf-cat-icon"><%= ({
                'vehicles':       '🚗',
                'mobiles':        '📱',
                'home-appliances':'❄️',
                'furniture':      '🛋️',
                'kitchen-tools':  '🍳',
                'computers':      '💻',
                'livestock':      '🐄',
                'crops':          '🌾',
                'real-estate':    '🏠',
                'professions':    '🔧'
              })[cat.slug] || '📦' %></span>
              <span class="pf-cat-label"><%= cat.name %></span>
            </button>
          <% }) %>
        </div>
      </div>

      <!-- Sub Category -->
      <div class="form-group" id="subCatGroup" style="display:none;">
        <label for="subCatSelect">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          الفئة الفرعية
        </label>
        <div class="pf-custom-select-wrap">
          <select id="subCatSelect" class="pf-custom-select">
            <option value="">— اختر الفئة الفرعية —</option>
          </select>
          <span class="pf-select-arrow">▾</span>
        </div>
      </div>
    </div>

    <!-- ===== STEP 3: DYNAMIC ATTRIBUTE FIELDS ===== -->
    <div class="pf-section" id="attrSection" style="display:none;">
      <div class="pf-section-title">
        <span class="pf-step">٣</span>
        <span>تفاصيل المنتج</span>
      </div>
      <div id="attrFields" class="pf-attr-grid"></div>
    </div>

    <!-- ===== STEP 4: DESCRIPTION ===== -->
    <div class="pf-section">
      <div class="pf-section-title">
        <span class="pf-step" id="descStep">٤</span>
        <span>الوصف والمواصفات</span>
      </div>
      <div class="form-group">
        <label for="description">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          وصف إضافي / المواصفات
        </label>
        <textarea id="description" name="description" rows="4" class="pf-input" placeholder="اكتب أي تفاصيل إضافية أو مواصفات تريد إضافتها..."><%= (old && old.description) || (product && product.description) || '' %></textarea>
      </div>
    </div>

    <!-- ===== STEP 5: PRICE & QUANTITY ===== -->
    <div class="pf-section">
      <div class="pf-section-title">
        <span class="pf-step">٥</span>
        <span>السعر والكمية</span>
      </div>
      <div class="pf-two-col">
        <div class="form-group">
          <label for="price">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            السعر (ج.م)
          </label>
          <input type="number" id="price" name="price" step="0.01" min="0"
            value="<%= (old && old.price) || (product && product.price) || '' %>"
            placeholder="0.00" required class="pf-input">
        </div>
        <div class="form-group">
          <label for="quantity">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            الكمية المتوفرة
          </label>
          <input type="number" id="quantity" name="quantity" step="1" min="0"
            value="<%= (old && old.quantity !== undefined) ? old.quantity : (product ? product.quantity : '') %>"
            placeholder="1" required class="pf-input">
        </div>
      </div>
    </div>

    <!-- ===== STEP 6: IMAGES ===== -->
    <div class="pf-section">
      <div class="pf-section-title">
        <span class="pf-step">٦</span>
        <span>الصور</span>
      </div>
      <% if (images && images.length > 0) { %>
        <div class="form-group">
          <label>الصور الحالية</label>
          <div class="image-thumbs">
            <% images.forEach(function(img) { %>
              <img src="/uploads/<%= img.image_url %>" alt="صورة المنتج" class="thumb">
            <% }) %>
          </div>
        </div>
      <% } %>
      <div class="form-group">
        <label for="images">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          إضافة صور المنتج
        </label>
        <div class="pf-file-wrap">
          <label for="images" class="pf-file-label">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
            اختر الصور أو اسحبها هنا
          </label>
          <input type="file" id="images" name="images" accept="image/jpeg,image/png,image/webp" multiple class="pf-file-input">
          <p class="pf-file-hint">يمكن اختيار أكثر من صورة — JPEG, PNG, WebP</p>
        </div>
      </div>
    </div>

    <div class="pf-submit-row">
      <button type="submit" class="btn btn-primary pf-submit">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        <%= mode === 'create' ? 'نشر المنتج' : 'حفظ التعديلات' %>
      </button>
      <a href="/vendor/products" class="btn btn-secondary">إلغاء</a>
    </div>
  </form>
</div>

<script>
(function () {
  const SUBS_MAP = <%- subsMap %>;

  // ─── Attribute field definitions per subcategory slug ───────────────────────
  const COND_OPTS = ['جديد', 'مستعمل بحالة ممتازة', 'مستعمل بحالة جيدة', 'مستعمل'];
  const COND_SIMPLE = ['جديد', 'مستعمل'];
  const GENDER_OPTS = ['ذكر', 'أنثى'];

  const ATTR_CONFIG = {
    'vehicles-for-sale': [
      { name:'brand',     label:'الماركة / الشركة',       icon:'🏭', type:'text' },
      { name:'model',     label:'الموديل',                 icon:'🔖', type:'text' },
      { name:'year',      label:'سنة الصنع',               icon:'📅', type:'number', min:1960, max:2025 },
      { name:'condition', label:'الحالة',                  icon:'✅', type:'select', options: COND_SIMPLE },
      { name:'mileage',   label:'عداد الكيلومترات',        icon:'🛣️', type:'number', min:0 },
      { name:'color',     label:'اللون',                   icon:'🎨', type:'text' },
    ],
    'spare-parts': [
      { name:'compatible_with', label:'مناسب لسيارة / موديل', icon:'🔗', type:'text' },
      { name:'condition',       label:'الحالة',               icon:'✅', type:'select', options: COND_SIMPLE },
    ],
    'motorcycles': [
      { name:'brand',     label:'الماركة',   icon:'🏭', type:'text' },
      { name:'model',     label:'الموديل',   icon:'🔖', type:'text' },
      { name:'year',      label:'سنة الصنع', icon:'📅', type:'number', min:1960, max:2025 },
      { name:'condition', label:'الحالة',    icon:'✅', type:'select', options: COND_SIMPLE },
      { name:'color',     label:'اللون',     icon:'🎨', type:'text' },
    ],
    'vehicle-accessories': [
      { name:'condition', label:'الحالة', icon:'✅', type:'select', options: COND_SIMPLE },
    ],
    'mobile-phones': [
      { name:'brand',     label:'الماركة',          icon:'🏭', type:'text' },
      { name:'model',     label:'الموديل',           icon:'🔖', type:'text' },
      { name:'storage',   label:'السعة التخزينية',   icon:'💾', type:'text', placeholder:'مثال: 128GB' },
      { name:'ram',       label:'الرام',             icon:'⚡', type:'text', placeholder:'مثال: 8GB' },
      { name:'condition', label:'الحالة',            icon:'✅', type:'select', options: COND_OPTS },
      { name:'color',     label:'اللون',             icon:'🎨', type:'text' },
    ],
    'tablets': [
      { name:'brand',     label:'الماركة',        icon:'🏭', type:'text' },
      { name:'model',     label:'الموديل',         icon:'🔖', type:'text' },
      { name:'storage',   label:'السعة التخزينية', icon:'💾', type:'text', placeholder:'مثال: 64GB' },
      { name:'condition', label:'الحالة',          icon:'✅', type:'select', options: COND_OPTS },
    ],
    'earphones': [
      { name:'brand',     label:'الماركة', icon:'🏭', type:'text' },
      { name:'condition', label:'الحالة',  icon:'✅', type:'select', options: COND_SIMPLE },
    ],
    'wireless-headphones': [
      { name:'brand',     label:'الماركة',          icon:'🏭', type:'text' },
      { name:'condition', label:'الحالة',           icon:'✅', type:'select', options: COND_SIMPLE },
      { name:'battery',   label:'عمر البطارية',     icon:'🔋', type:'text', placeholder:'مثال: 30 ساعة' },
    ],
    // Home appliances – shared config
    'refrigerators':    _homeAppliance(),
    'deep-freezers':    _homeAppliance(),
    'water-filters':    _homeAppliance(),
    'air-conditioners': _homeAppliance(),
    'fans':             _homeAppliance(),
    'water-heaters':    _homeAppliance(),
    'room-heaters':     _homeAppliance(),
    'kettles':          _homeAppliance(),
    'screens-tvs':      [
      { name:'brand',     label:'الماركة',    icon:'🏭', type:'text' },
      { name:'size',      label:'المقاس',     icon:'📐', type:'text', placeholder:'مثال: 55 بوصة' },
      { name:'condition', label:'الحالة',     icon:'✅', type:'select', options: COND_SIMPLE },
      { name:'warranty',  label:'الضمان',     icon:'🛡️', type:'text', placeholder:'مثال: سنة' },
    ],
    // Furniture
    'beds':             _furniture(),
    'bedrooms':         _furniture(),
    'kitchen-furniture':_furniture(),
    'sofas':            _furniture(),
    'chairs':           _furniture(),
    'desks':            _furniture(),
    // Kitchen tools
    'pots':           _kitchenTool(),
    'bowls':          _kitchenTool(),
    'plates':         _kitchenTool(),
    'spoons':         _kitchenTool(),
    'forks':          _kitchenTool(),
    'knives':         _kitchenTool(),
    'ladles':         _kitchenTool(),
    'wooden-spoons':  _kitchenTool(),
    // Computers
    'desktop-computers': _computer(),
    'laptops': _computer(),
    'computer-accessories': [
      { name:'compatible_with', label:'متوافق مع',  icon:'🔗', type:'text' },
      { name:'condition',       label:'الحالة',      icon:'✅', type:'select', options: COND_SIMPLE },
    ],
    'printers': [
      { name:'brand',     label:'الماركة', icon:'🏭', type:'text' },
      { name:'condition', label:'الحالة',  icon:'✅', type:'select', options: COND_SIMPLE },
    ],
    // Livestock large
    'cows':    _livestock(),
    'camels':  _livestock(),
    'goats':   _livestock(),
    'sheep':   _livestock(),
    'horses':  _livestock(),
    'donkeys': _livestock(),
    // Pets
    'cats': _pet(),
    'dogs': _pet(),
    'turtles': [
      { name:'age', label:'العمر التقريبي', icon:'🎂', type:'text', placeholder:'مثال: سنة' },
    ],
    'ornamental-fish': [
      { name:'species', label:'النوع / الفصيلة', icon:'🐟', type:'text' },
    ],
    // Crops
    'vegetables': _crop(),
    'fruits':     _crop(),
    // Real estate for sale
    'apartments-for-sale': _realEstateSale(),
    'houses-for-sale':     _realEstateSale(),
    'apartments-for-rent': _realEstateRent(),
    'houses-for-rent':     _realEstateRent(),
    // Land
    'agricultural-land':  _land(),
    'residential-land':   _land(),
    'commercial-land':    _land(),
    'industrial-land':    _land(),
    // Professions
    'electricians':     _profession(),
    'plumbers':         _profession(),
    'carpenters':       _profession(),
    'ac-technicians':   _profession(),
    'car-mechanics':    _profession(),
  };

  function _homeAppliance() {
    return [
      { name:'brand',     label:'الماركة',  icon:'🏭', type:'text' },
      { name:'condition', label:'الحالة',   icon:'✅', type:'select', options: COND_SIMPLE },
      { name:'warranty',  label:'الضمان',   icon:'🛡️', type:'text', placeholder:'مثال: سنة أو بدون' },
    ];
  }
  function _furniture() {
    return [
      { name:'condition', label:'الحالة',   icon:'✅', type:'select', options: COND_SIMPLE },
      { name:'material',  label:'الخامة',   icon:'🪵', type:'text', placeholder:'مثال: خشب – معدن' },
      { name:'color',     label:'اللون',    icon:'🎨', type:'text' },
    ];
  }
  function _kitchenTool() {
    return [
      { name:'condition', label:'الحالة',  icon:'✅', type:'select', options: COND_SIMPLE },
      { name:'material',  label:'الخامة',  icon:'🪵', type:'text', placeholder:'مثال: ستانلس – ألومنيوم' },
    ];
  }
  function _computer() {
    return [
      { name:'brand',     label:'الماركة',  icon:'🏭', type:'text' },
      { name:'processor', label:'المعالج',  icon:'⚙️', type:'text', placeholder:'مثال: Core i7' },
      { name:'ram',       label:'الرام',    icon:'⚡', type:'text', placeholder:'مثال: 16GB' },
      { name:'storage',   label:'التخزين',  icon:'💾', type:'text', placeholder:'مثال: 512GB SSD' },
      { name:'condition', label:'الحالة',   icon:'✅', type:'select', options: COND_OPTS },
    ];
  }
  function _livestock() {
    return [
      { name:'age',    label:'العمر',           icon:'🎂', type:'text', placeholder:'مثال: سنتان' },
      { name:'gender', label:'الجنس',           icon:'⚥',  type:'select', options: GENDER_OPTS },
      { name:'weight', label:'الوزن التقريبي',  icon:'⚖️', type:'text', placeholder:'مثال: 200 كجم' },
    ];
  }
  function _pet() {
    return [
      { name:'breed',  label:'السلالة / الفصيلة', icon:'🐾', type:'text' },
      { name:'age',    label:'العمر',              icon:'🎂', type:'text', placeholder:'مثال: 6 أشهر' },
      { name:'gender', label:'الجنس',              icon:'⚥',  type:'select', options: GENDER_OPTS },
    ];
  }
  function _crop() {
    return [
      { name:'unit',   label:'وحدة البيع', icon:'📦', type:'select', options:['كيلو','طن','قنطار','كرتونة','قطعة','حبة'] },
      { name:'season', label:'الموسم',     icon:'🌱', type:'text', placeholder:'مثال: صيفي' },
    ];
  }
  function _realEstateSale() {
    return [
      { name:'area_sqm',  label:'المساحة (متر مربع)',  icon:'📐', type:'number', min:1 },
      { name:'floor',     label:'الدور',               icon:'🏢', type:'text', placeholder:'مثال: الثالث' },
      { name:'rooms',     label:'عدد الغرف',            icon:'🛏️', type:'number', min:1 },
      { name:'bathrooms', label:'عدد الحمامات',         icon:'🚿', type:'number', min:1 },
      { name:'finishing', label:'التشطيب',              icon:'🏗️', type:'select', options:['سوبر لوكس','لوكس','عادي','بدون تشطيب'] },
    ];
  }
  function _realEstateRent() {
    return [
      { name:'area_sqm',       label:'المساحة (متر مربع)', icon:'📐', type:'number', min:1 },
      { name:'floor',          label:'الدور',              icon:'🏢', type:'text', placeholder:'مثال: الثالث' },
      { name:'rooms',          label:'عدد الغرف',           icon:'🛏️', type:'number', min:1 },
      { name:'bathrooms',      label:'عدد الحمامات',        icon:'🚿', type:'number', min:1 },
      { name:'furnished',      label:'التأثيث',             icon:'🪑', type:'select', options:['مفروشة','غير مفروشة'] },
      { name:'payment_period', label:'فترة الدفع',          icon:'📅', type:'select', options:['شهري','ربع سنوي','نصف سنوي','سنوي'] },
    ];
  }
  function _land() {
    return [
      { name:'area_sqm', label:'المساحة (متر مربع)', icon:'📐', type:'number', min:1 },
    ];
  }
  function _profession() {
    return [
      { name:'experience',   label:'سنوات الخبرة', icon:'⭐', type:'text', placeholder:'مثال: 5 سنوات' },
      { name:'availability', label:'أوقات العمل',  icon:'🕐', type:'text', placeholder:'مثال: يومياً 8ص – 5م' },
      { name:'service_area', label:'منطقة الخدمة', icon:'📍', type:'text', placeholder:'مثال: مغاغة وضواحيها' },
    ];
  }

  // ─── Saved values for edit mode ─────────────────────────────────────────────
  const savedAttrs    = <%- JSON.stringify(locals.productAttrs || {}) %>;
  const savedCatId    = parseInt('<%= (old && old.categoryId) || (product && product.category_id) || "" %>') || null;
  const savedMainId   = findMainForSub(savedCatId);

  // ─── DOM refs ───────────────────────────────────────────────────────────────
  const mainGrid      = document.getElementById('mainCatGrid');
  const subGroup      = document.getElementById('subCatGroup');
  const subSelect     = document.getElementById('subCatSelect');
  const attrSection   = document.getElementById('attrSection');
  const attrFields    = document.getElementById('attrFields');
  const hiddenCatId   = document.getElementById('categoryId');

  // ─── Helpers ────────────────────────────────────────────────────────────────
  function findMainForSub(subId) {
    if (!subId) return null;
    for (const [mainId, subs] of Object.entries(SUBS_MAP)) {
      if (subs.some(s => s.id === subId)) return parseInt(mainId);
    }
    return null;
  }

  function selectMain(mainId, mainSlug) {
    document.querySelectorAll('.pf-cat-chip').forEach(el => el.classList.remove('active'));
    const chip = mainGrid.querySelector(`[data-id="${mainId}"]`);
    if (chip) chip.classList.add('active');

    const subs = SUBS_MAP[mainId] || [];
    subSelect.innerHTML = '<option value="">— اختر الفئة الفرعية —</option>';
    subs.forEach(s => {
      const opt = document.createElement('option');
      opt.value = s.id;
      opt.textContent = s.name;
      subSelect.appendChild(opt);
    });
    subGroup.style.display = subs.length ? 'block' : 'none';

    clearAttrFields();
  }

  function selectSub(subId) {
    hiddenCatId.value = subId || '';
    if (!subId) { clearAttrFields(); return; }
    const slug = Array.from(subSelect.options).find(o => o.value == subId)?.dataset?.slug;
    const subSlug = (function() {
      for (const [, subs] of Object.entries(SUBS_MAP)) {
        const found = subs.find(s => s.id == subId);
        if (found) return found.slug;
      }
      return null;
    })();
    renderAttrFields(subSlug);
  }

  function clearAttrFields() {
    attrSection.style.display = 'none';
    attrFields.innerHTML = '';
  }

  function renderAttrFields(subSlug) {
    const config = ATTR_CONFIG[subSlug];
    if (!config || config.length === 0) { clearAttrFields(); return; }

    attrFields.innerHTML = '';
    config.forEach(function(field) {
      const saved = savedAttrs[field.name] || '';
      const div = document.createElement('div');
      div.className = 'pf-attr-field';

      let inputHtml = '';
      if (field.type === 'select') {
        const opts = field.options.map(o =>
          `<option value="${o}" ${saved === o ? 'selected' : ''}>${o}</option>`
        ).join('');
        inputHtml = `<select name="attr_${field.name}" class="pf-input"><option value="">— اختر —</option>${opts}</select>`;
      } else {
        const extra = field.min !== undefined ? `min="${field.min}"` : '';
        const extra2 = field.max !== undefined ? `max="${field.max}"` : '';
        const ph = field.placeholder ? `placeholder="${field.placeholder}"` : '';
        inputHtml = `<input type="${field.type}" name="attr_${field.name}" value="${saved}" class="pf-input" ${extra} ${extra2} ${ph}>`;
      }

      div.innerHTML = `
        <label>
          <span class="pf-attr-icon">${field.icon}</span>
          ${field.label}
        </label>
        ${inputHtml}
      `;
      attrFields.appendChild(div);
    });

    attrSection.style.display = 'block';
  }

  // ─── Event listeners ────────────────────────────────────────────────────────
  mainGrid.addEventListener('click', function(e) {
    const chip = e.target.closest('.pf-cat-chip');
    if (!chip) return;
    selectMain(parseInt(chip.dataset.id), chip.dataset.slug);
    hiddenCatId.value = '';
    clearAttrFields();
  });

  subSelect.addEventListener('change', function() {
    selectSub(this.value);
  });

  // ─── Restore saved state (edit mode) ────────────────────────────────────────
  if (savedMainId) {
    selectMain(savedMainId, '');
    if (savedCatId) {
      subSelect.value = savedCatId;
      selectSub(savedCatId);
    }
  }
})();
</script>

