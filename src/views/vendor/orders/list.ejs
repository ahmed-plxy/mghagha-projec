<%- include('../../partials/header', { title: 'الطلبات الواردة' }) %>
<div class="container">
  <h1>الطلبات الواردة</h1>

  <div class="tabs">
    <a href="/vendor/orders" class="<%= currentStatus === 'all' ? 'tab active' : 'tab' %>">الكل</a>
    <a href="/vendor/orders?status=pending" class="<%= currentStatus === 'pending' ? 'tab active' : 'tab' %>">قيد الانتظار</a>
    <a href="/vendor/orders?status=confirmed" class="<%= currentStatus === 'confirmed' ? 'tab active' : 'tab' %>">مؤكد</a>
    <a href="/vendor/orders?status=preparing" class="<%= currentStatus === 'preparing' ? 'tab active' : 'tab' %>">قيد التحضير</a>
    <a href="/vendor/orders?status=out_for_delivery" class="<%= currentStatus === 'out_for_delivery' ? 'tab active' : 'tab' %>">في الطريق</a>
    <a href="/vendor/orders?status=delivered" class="<%= currentStatus === 'delivered' ? 'tab active' : 'tab' %>">تم التوصيل</a>
    <a href="/vendor/orders?status=cancelled" class="<%= currentStatus === 'cancelled' ? 'tab active' : 'tab' %>">ملغي</a>
  </div>

  <% if (orders.length === 0) { %>
    <p>لا توجد طلبات في هذا التصنيف.</p>
  <% } else { %>
    <table class="data-table">
      <thead>
        <tr><th>رقم الطلب</th><th>الإجمالي</th><th>الحالة</th><th>تاريخ الطلب</th><th>الإجراء</th></tr>
      </thead>
      <tbody>
        <% orders.forEach(function(order) { %>
          <tr>
            <td><%= order.order_number %></td>
            <td><%= order.total_amount.toFixed(2) %> ج.م</td>
            <td><span class="badge badge-success"><%= orderStatusLabel(order.order_status) %></span></td>
            <td><%= order.created_at %></td>
            <td><a href="/vendor/orders/<%= order.id %>" class="btn btn-small btn-secondary">التفاصيل</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
<%- include('../../partials/footer') %>
