<%- include('../partials/header', { title: store.store_name }) %>
<div class="container">

  <%# ── Store Header Card ── %>
  <div class="sp-header-card">
    <% if (store.cover_image) { %>
      <div class="sp-cover">
        <img src="/uploads/<%= store.cover_image %>" alt="<%= store.store_name %>">
      </div>
    <% } %>
    <div class="sp-header-body">
      <div class="sp-logo-wrap">
        <% if (store.logo_image) { %>
          <img src="/uploads/<%= store.logo_image %>" alt="<%= store.store_name %>" class="sp-logo">
        <% } else { %>
          <div class="sp-logo-placeholder"><%= store.store_name.charAt(0) %></div>
        <% } %>
      </div>
      <div class="sp-header-info">
        <h1 class="sp-store-name"><%= store.store_name %></h1>
        <div class="sp-meta-row">
          <span class="sp-meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <%= store.area_name %>
          </span>
          <% if (store.rating_average > 0) { %>
            <span class="sp-rating-badge">
              ★ <%= store.rating_average.toFixed(1) %> / 5
            </span>
          <% } %>
          <span class="sp-meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            عضو منذ <%= new Date(store.created_at).getFullYear() %>
          </span>
        </div>
        <% if (store.description) { %>
          <p class="sp-description"><%= store.description %></p>
        <% } %>
      </div>
    </div>
    <% if (currentUser && currentUser.role === 'customer') { %>
      <form action="/customer/messages/start" method="POST" class="sp-contact-form">
        <input type="hidden" name="storeId" value="<%= store.id %>">
        <button type="submit" class="sp-contact-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          تواصل مع البائع
        </button>
      </form>
    <% } else if (!currentUser) { %>
      <a href="/auth/login" class="sp-contact-btn" style="text-decoration:none;text-align:center;">
        سجل الدخول للتواصل
      </a>
    <% } %>
  </div>

  <%# ── Products Grid ── %>
  <h2 class="sp-products-title">منتجات المتجر <span class="sp-count">(<%= products.length %>)</span></h2>
  <% if (products.length === 0) { %>
    <div class="sp-empty">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
      <p>لا توجد منتجات متاحة حاليًا في هذا المتجر.</p>
    </div>
  <% } else { %>
    <div class="sp-grid">
      <% products.forEach(function(product) { %>
        <a href="/stores/<%= store.store_slug %>/products/<%= product.slug %>" class="sp-product-card">
          <div class="sp-product-img-wrap">
            <% if (product.image_url) { %>
              <img src="/uploads/<%= product.image_url %>" alt="<%= product.name %>">
            <% } else { %>
              <div class="sp-product-no-img">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              </div>
            <% } %>
          </div>
          <div class="sp-product-body">
            <p class="sp-product-name"><%= product.name %></p>
            <p class="sp-product-price"><%= product.price.toFixed(0) %> <span>ج.م</span></p>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>

</div>

<style>
/* Header Card */
.sp-header-card {
  border: 1.5px solid var(--color-border);
  border-radius: 18px; overflow: hidden;
  margin-bottom: 24px;
  background: var(--color-bg);
}
.sp-cover { width: 100%; height: 160px; overflow: hidden; background: var(--color-bg-alt); }
.sp-cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
.sp-header-body { display: flex; gap: 14px; padding: 16px; align-items: flex-start; }
.sp-logo-wrap { flex-shrink: 0; }
.sp-logo { width: 64px; height: 64px; border-radius: 12px; object-fit: cover; border: 2px solid var(--color-border); }
.sp-logo-placeholder {
  width: 64px; height: 64px; border-radius: 12px;
  background: var(--color-primary); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.8rem; font-weight: 800;
}
.sp-header-info { flex: 1; }
.sp-store-name { font-size: 1.3rem; font-weight: 800; margin: 0 0 6px; }
.sp-meta-row { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; margin-bottom: 6px; }
.sp-meta-item { display: flex; align-items: center; gap: 4px; font-size: .8rem; color: var(--color-muted); }
.sp-rating-badge {
  background: #fef3c7; color: #92400e; border-radius: 20px;
  padding: 2px 9px; font-size: .78rem; font-weight: 700;
}
.sp-description { font-size: .88rem; color: var(--color-muted); margin: 4px 0 0; line-height: 1.5; }
.sp-contact-form { padding: 0 16px 16px; }
.sp-contact-btn {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  width: 100%; background: var(--color-primary); color: #fff;
  border: none; border-radius: 10px; padding: 12px; font-size: .9rem;
  font-weight: 700; cursor: pointer; transition: background .18s; font-family: inherit;
}
.sp-contact-btn:hover { background: var(--color-primary-dark, #155e38); color: #fff; text-decoration: none; }

/* Products */
.sp-products-title { font-size: 1.05rem; font-weight: 800; margin: 0 0 14px; }
.sp-count { font-size: .85rem; font-weight: 600; color: var(--color-muted); }
.sp-empty { text-align: center; padding: 48px 16px; color: var(--color-muted); display: flex; flex-direction: column; align-items: center; gap: 12px; }
.sp-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
  gap: 12px;
}
@media (max-width: 400px) { .sp-grid { grid-template-columns: repeat(2, 1fr); } }
.sp-product-card {
  border: 1.5px solid var(--color-border); border-radius: 12px;
  overflow: hidden; text-decoration: none; color: var(--color-text);
  background: var(--color-bg); transition: border-color .18s, box-shadow .18s;
}
.sp-product-card:hover { border-color: var(--color-primary); box-shadow: 0 4px 16px rgba(0,0,0,.08); }
.sp-product-img-wrap { aspect-ratio: 1/1; background: var(--color-bg-alt); overflow: hidden; }
.sp-product-img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .25s; }
.sp-product-card:hover .sp-product-img-wrap img { transform: scale(1.04); }
.sp-product-no-img { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: var(--color-muted); }
.sp-product-body { padding: 10px; }
.sp-product-name { font-size: .85rem; font-weight: 700; margin: 0 0 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.sp-product-price { font-size: .9rem; font-weight: 800; color: var(--color-primary); margin: 0; }
.sp-product-price span { font-size: .78rem; font-weight: 600; }
</style>

<%- include('../partials/footer') %>
