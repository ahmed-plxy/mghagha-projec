<%- include('../partials/header', { title: 'افتح حساب' }) %>

<div class="auth-page">
  <div class="auth-card auth-card-wide">

    <div class="auth-brand">
      <div class="auth-logo">🛍️</div>
      <h1 class="auth-title">افتح حساب جديد</h1>
      <p class="auth-subtitle">انضم لمجتمع متجر مغاغة المحلي</p>
    </div>

    <% if (errors && errors.length > 0) { %>
      <div class="auth-alert auth-alert-error">
        <% errors.forEach(function(err) { %><p>⚠ <%= err %></p><% }) %>
      </div>
    <% } %>

    <% const googleEnabled = locals.googleEnabled; %>
    <% if (googleEnabled) { %>
      <a href="/auth/google" class="btn-google">
        <svg width="20" height="20" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        سجّل بحساب جوجل
      </a>
      <div class="auth-divider"><span>أو بالتليفون</span></div>
    <% } %>

    <form action="/auth/register" method="POST" class="auth-form" autocomplete="on" id="registerForm">

      <div class="auth-field">
        <label for="fullName">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          الاسم الكامل
        </label>
        <input type="text" id="fullName" name="fullName"
          value="<%= old.fullName || '' %>"
          placeholder="مثال: محمد أحمد السيد"
          required autocomplete="name" class="auth-input">
        <span class="auth-hint">اسمك الحقيقي — 3 حروف على الأقل</span>
      </div>

      <div class="auth-two-col">
        <div class="auth-field">
          <label for="phone">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.58 3.45 2 2 0 0 1 3.55 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.82a16 16 0 0 0 6.27 6.27l1.62-1.62a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            رقم التليفون
          </label>
          <input type="tel" id="phone" name="phone"
            value="<%= old.phone || '' %>"
            placeholder="01012345678"
            required autocomplete="tel" class="auth-input" inputmode="numeric">
          <span class="auth-hint">رقم مصري يبدأ بـ 010/011/012/015</span>
        </div>

        <div class="auth-field">
          <label for="email">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            الإيميل
          </label>
          <input type="email" id="email" name="email"
            value="<%= old.email || '' %>"
            placeholder="example@gmail.com"
            autocomplete="email" class="auth-input">
          <span class="auth-hint">اختياري</span>
        </div>
      </div>

      <%# Area Selection %>
      <div class="auth-field">
        <label for="areaId">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          منطقتك أو قريتك
        </label>
        <select id="areaId" name="areaId" required class="auth-input" style="appearance:auto;">
          <option value="">-- اختار منطقتك --</option>
          <% if (areas && areas.length > 0) { %>
            <% areas.forEach(function(area) { %>
              <option value="<%= area.id %>" <%= (old.areaId && old.areaId == area.id) ? 'selected' : '' %>>
                <%= area.name %>
              </option>
            <% }) %>
          <% } %>
        </select>
        <span class="auth-hint">اختار المنطقة الأقرب ليك</span>
      </div>

      <div class="auth-two-col">
        <div class="auth-field">
          <label for="password">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            كلمة السر
          </label>
          <div class="auth-input-wrap">
            <input type="password" id="password" name="password"
              required minlength="8" autocomplete="new-password"
              class="auth-input" placeholder="••••••••">
            <button type="button" class="auth-eye-btn" onclick="togglePass('password',this)" tabindex="-1">
              <svg class="eye-show" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              <svg class="eye-hide" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
            </button>
          </div>
          <span class="auth-hint">8 حروف على الأقل</span>
        </div>

        <div class="auth-field">
          <label for="confirmPassword">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            تأكيد كلمة السر
          </label>
          <div class="auth-input-wrap">
            <input type="password" id="confirmPassword" name="confirmPassword"
              required minlength="8" autocomplete="new-password"
              class="auth-input" placeholder="••••••••">
            <button type="button" class="auth-eye-btn" onclick="togglePass('confirmPassword',this)" tabindex="-1">
              <svg class="eye-show" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              <svg class="eye-hide" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
            </button>
          </div>
          <span class="auth-hint" id="matchHint"></span>
        </div>
      </div>

      <%# Terms Checkbox %>
      <div class="auth-terms-wrap">
        <label class="auth-terms-label">
          <input type="checkbox" id="agreeTerms" name="agreeTerms" value="1" onchange="toggleSubmit()">
          <span>
            أوافق على
            <a href="/privacy" target="_blank">سياسة الخصوصية</a>
            و
            <a href="/terms" target="_blank">اتفاقية البيع والشراء</a>
            الخاصة بتطبيق مغاغة
          </span>
        </label>
      </div>

      <button type="submit" class="btn-auth-primary" id="submitBtn" disabled>افتح الحساب</button>
    </form>

    <p class="auth-switch">
      عندك حساب أصلاً؟ <a href="/auth/login">ادخل من هنا</a>
    </p>
  </div>
</div>

<style>
.auth-terms-wrap {
  background: var(--color-bg-alt);
  border: 1.5px solid var(--color-border);
  border-radius: 10px;
  padding: 12px 14px;
  margin-bottom: 14px;
}
.auth-terms-label {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  cursor: pointer;
  font-size: .88rem;
  line-height: 1.5;
  color: var(--color-text);
}
.auth-terms-label input[type="checkbox"] {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
  margin-top: 1px;
  accent-color: var(--color-primary);
  cursor: pointer;
}
.auth-terms-label a { color: var(--color-primary); text-decoration: underline; }
#submitBtn:disabled { opacity: .5; cursor: not-allowed; }
</style>

<script>
function togglePass(id, btn) {
  var inp = document.getElementById(id);
  var show = btn.querySelector('.eye-show');
  var hide = btn.querySelector('.eye-hide');
  if (inp.type === 'password') {
    inp.type = 'text'; show.style.display = 'none'; hide.style.display = '';
  } else {
    inp.type = 'password'; show.style.display = ''; hide.style.display = 'none';
  }
}

document.getElementById('confirmPassword').addEventListener('input', function() {
  var pass = document.getElementById('password').value;
  var hint = document.getElementById('matchHint');
  if (!this.value) { hint.textContent = ''; return; }
  if (this.value === pass) {
    hint.textContent = '✓ كلمتين السر متطابقتين';
    hint.style.color = 'var(--color-primary)';
  } else {
    hint.textContent = '✗ كلمتين السر مش زي بعض';
    hint.style.color = 'var(--color-danger)';
  }
});

function toggleSubmit() {
  var checked = document.getElementById('agreeTerms').checked;
  document.getElementById('submitBtn').disabled = !checked;
}
</script>

<%- include('../partials/footer') %>
