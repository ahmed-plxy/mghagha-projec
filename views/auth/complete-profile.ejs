<%- include('../partials/header', { title: 'أكمل بياناتك' }) %>

<div class="auth-page">
  <div class="auth-card">

    <div class="auth-brand">
      <div class="auth-logo">📱</div>
      <h1 class="auth-title">أكمل بياناتك</h1>
      <p class="auth-subtitle">أضف رقم هاتفك لإكمال حسابك — مطلوب عند الطلب والشراء</p>
    </div>

    <% if (errors && errors.length > 0) { %>
      <div class="auth-alert auth-alert-error">
        <% errors.forEach(function(err) { %><p>⚠ <%= err %></p><% }) %>
      </div>
    <% } %>

    <div class="complete-profile-info">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <span>تم تسجيل دخولك بنجاح عبر جوجل. نحتاج رقم هاتفك المصري لاستكمال حسابك.</span>
    </div>

    <form action="/auth/complete-profile" method="POST" class="auth-form">
      <div class="auth-field">
        <label for="phone">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.58 3.45 2 2 0 0 1 3.55 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.82a16 16 0 0 0 6.27 6.27l1.62-1.62a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          رقم الهاتف المصري
        </label>
        <input
          type="tel"
          id="phone"
          name="phone"
          value="<%= old.phone || '' %>"
          placeholder="01012345678"
          required
          autofocus
          autocomplete="tel"
          class="auth-input"
          inputmode="numeric"
          maxlength="11"
        >
      </div>

      <button type="submit" class="btn-auth-primary">حفظ رقم الهاتف والمتابعة</button>
    </form>

    <p class="auth-switch" style="margin-top:16px;">
      <a href="/auth/logout" style="color:var(--color-muted);font-size:0.88rem;">تسجيل الخروج</a>
    </p>
  </div>
</div>

<style>
.complete-profile-info {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  background: #e8f4fd;
  border: 1px solid #b3d9f7;
  border-radius: 10px;
  padding: 12px 14px;
  margin-bottom: 20px;
  color: #1a5e8a;
  font-size: 0.9rem;
  line-height: 1.5;
}
.complete-profile-info svg {
  stroke: #1a7abf;
  flex-shrink: 0;
  margin-top: 1px;
}
</style>

<%- include('../partials/footer') %>
